# ── agent server — local env ─────────────────────────────────────────────────
# Copy to .env (gitignored) and fill in. Loaded by the dev script
# (ts-node-dev -r dotenv/config) and the VS Code debugger (envFile).
#
# LOCAL MODE: when NODE_ENV != production the server runs in local mode (src/local.ts):
#   - a dev identity (DEV_USER_EMAIL / first ADMIN_EMAILS) is assumed — no OAuth login
#     needed; unlocks Gmail/Calendar/Tasks/memory/Apollo/custom-tools/chat history.
#   - flows are stored in a local JSON file instead of Cloud Scheduler (cron won't fire;
#     webhook + manual runs work).
#   - requireAdmin is bypassed.
# All of this is OFF in production (NODE_ENV=production set by the deploy workflows).

# ── Minimum to boot + use the LLM ────────────────────────────────────────────
GEMINI_API_KEY=            # or ANTHROPIC_API_KEY / OPENAI_API_KEY (match config.ts model.provider)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
PORT=8080
NODE_ENV=development
# DEV_USER_EMAIL=          # local dev identity (defaults to first ADMIN_EMAILS entry)

# ── Connections (read the SAME Firestore data as a deployed agent) ────────────
# Point these at the shared oauth-service + the agent's GCP project id so local runs
# resolve the same tokens/custom-tools/flow-runs as that deployed agent.
OAUTH_SERVICE_URL=         # e.g. https://oauth-service-XXXX.us-central1.run.app
OAUTH_SERVICE_KEY=         # this agent's key (or the master key)
GOOGLE_CLOUD_PROJECT=      # the agent's GCP project id (agentId), e.g. boost-<repo>

# Local-only Monday override: when set, all Monday calls use this token directly
# (bypasses the oauth-service) — handy when no Monday account is connected locally.
# MONDAY_TOKEN=

# ── Auth / sessions ───────────────────────────────────────────────────────────
COOKIE_SECRET=local-dev-secret
ADMIN_EMAILS=              # your email — becomes the local dev identity

# ── Flows ────────────────────────────────────────────────────────────────────
AUTOMATION_SECRET=local-automation-secret

# ── Optional ─────────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# GOOGLE_MAPS_API_KEY=
# JINA_API_KEY=
